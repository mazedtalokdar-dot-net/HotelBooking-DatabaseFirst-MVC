@model _1291163_MVC_Project.Models.guests

<div class="card mb-3 shadow-sm guest-detail-card">
    <div class="card-header text-white d-flex align-items-center justify-content-between"
         style="background: linear-gradient(90deg, #1d2671, #c33764); border-bottom: none;">

        <div class="d-flex align-items-center gap-3">
            @if (!string.IsNullOrEmpty(Model.picture))
            {
                <img src="@Model.picture" width="45" height="45"
                     class="rounded-circle border border-2 border-white shadow-sm"
                     alt="Guest" style="object-fit: cover;" />
            }
            else
            {
                <div class="rounded-circle bg-light text-dark d-flex align-items-center justify-content-center"
                     style="width: 45px; height: 45px;">
                    <i class="bi bi-person"></i>
                </div>
            }

            <div>
                <h6 class="mb-0 fw-bold">@Model.guestsName</h6>
                <small class="opacity-75">
                    <i class="bi bi-calendar-event me-1"></i>
                    @Model.bookingDate.ToString("dd MMM yyyy")
                </small>
            </div>
        </div>

        <button type="button" class="btn-close btn-close-white shadow-none"
                aria-label="Close"
                onclick="window.location.href='@Url.Action("Index", "Guests")';">
        </button>
    </div>

    <div class="card-body bg-white">
        <div class="row g-2">
            <div class="col-6">
                <p class="text-muted small mb-0 text-uppercase fw-bold">Guests Count</p>
                <p class="mb-0"><i class="bi bi-people me-2"></i>@Model.numberOfGueist Persons</p>
            </div>
            <div class="col-6 text-end">
                <p class="text-muted small mb-0 text-uppercase fw-bold">Status</p>
                <span class="badge rounded-pill @(Model.coupleStatus ? "bg-success" : "bg-info text-dark")">
                    @(Model.coupleStatus ? "Couple" : "Regular")
                </span>
            </div>
        </div>

        <hr class="my-3 text-muted opacity-25" />

        <div>
            <p class="text-muted small mb-2 text-uppercase fw-bold">Assigned Rooms</p>
            <div class="d-flex flex-wrap gap-1">
                @if (Model.bookingEntries != null && Model.bookingEntries.Any())
                {
                    foreach (var item in Model.bookingEntries)
                    {
                        <span class="badge bg-light text-dark border py-2 px-3">
                            <i class="bi bi-door-closed me-1"></i> @item.room.roomName
                        </span>
                    }
                }
                else
                {
                    <span class="text-muted italic small">No rooms assigned</span>
                }
            </div>
        </div>
    </div>
</div>