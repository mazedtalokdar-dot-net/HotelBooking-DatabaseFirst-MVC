@model _1291163_MVC_Project.Models.room

@{
    ViewBag.Title = "Delete Room";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="text-danger mb-0">Delete Room</h3>
    @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-outline-secondary btn-sm" })
</div>

<div class="card border-danger shadow-sm">
    <div class="card-body">

        <div class="alert alert-warning">
            <strong>Warning!</strong> Are you sure you want to delete this room?
        </div>

        <dl class="row mb-4">
            <dt class="col-sm-3">Room Number</dt>
            <dd class="col-sm-9 fw-semibold">
                @Html.DisplayFor(m => m.roomName)
            </dd>
        </dl>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    Delete
                </button>
                @Html.ActionLink("Cancel", "Index", null,
                    new { @class = "btn btn-outline-dark" })
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

