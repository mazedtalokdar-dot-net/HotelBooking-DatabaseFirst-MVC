@model _1291163_MVC_Project.Models.ViewModels.GuestVM

@{
    ViewBag.Title = "Delete Guest";
}

<div class="row">
    <div class="col-12">

        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fa fa-exclamation-triangle me-2"></i>
            <div>
                <strong>Confirm Delete:</strong> Are you sure you want to delete this guest booking information?
            </div>
        </div>

        @using (Html.BeginForm("Delete", "Guests", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken();

            @Html.HiddenFor(x => x.guestsId)
            @Html.HiddenFor(x => x.picture)

            <div class="row">
                <!-- Left: Guest Info -->
                <div class="col-12 col-lg-6">

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.guestsName, new { @class = "col-form-label col-form-label-sm col-4" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.guestsName, new { @class = "form-control form-control-sm", @readonly = "readonly" })
                        </div>
                    </div>

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.bookingDate, new { @class = "col-form-label col-form-label-sm col-4" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.bookingDate, "{0:yyyy-MM-dd}",
                                new { @class = "form-control form-control-sm", type = "date", disabled = "disabled" })

                        </div>
                    </div>

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.numberOfGueist, new { @class = "col-form-label col-form-label-sm col-4" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.numberOfGueist, new { @class = "form-control form-control-sm", @readonly = "readonly" })
                        </div>
                    </div>

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.coupleStatus, new { @class = "col-form-label col-form-label-sm col-4" })
                        <div class="col-8">
                            <span class="badge @(Model.coupleStatus ? "bg-success" : "bg-secondary")">
                                @(Model.coupleStatus ? "Couple" : "Regular")
                            </span>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-form-label col-form-label-sm col-4">Picture</label>
                        <div class="col-8">
                            <img src="@Model.picture" width="60" height="60"
                                 style="border-radius:10px; object-fit:cover;" />
                        </div>
                    </div>
                </div>

                <!-- Right: Booked Rooms -->
                <div class="border rounded p-2 bg-light">
                    @if (Model.RoomNames != null && Model.RoomNames.Count > 0)
                    {
                        foreach (var rn in Model.RoomNames)
                        {
                            <span class="badge bg-dark me-1 mb-1">@rn</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">No rooms found.</span>
                    }
                </div>

            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <input type="submit" value="Delete" class="btn btn-danger" />
                @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-outline-dark" })
            </div>
        }
    </div>
</div>

